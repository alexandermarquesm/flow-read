generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  provider   String
  providerId String   @unique
  avatarUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}
